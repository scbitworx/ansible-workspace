# =============================================================================
# Environment variables for docker-compose.yml
#
# These are set dynamically by run-agent.sh — this file is documentation only.
# Do NOT commit a real .env file (it would contain secrets).
# =============================================================================

# Claude API key (must be set in the host environment)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token (run-agent.sh reads this from `pass`)
GH_TOKEN=ghp_...

# Host filesystem path to the workspace (for bind mounts into containers).
# Defaults to the parent directory of tools/ when run via run-agent.sh.
HOST_WORKSPACE=/home/user/ansible-workspace

# Temp directory containing the ephemeral SSH keypair (created by run-agent.sh).
# Contains id_ed25519 and id_ed25519.pub.
SSH_TMPDIR=/tmp/tmp.XXXXXXXXXX
